# apps/client local dev environment
# Copy to .env.local (gitignored) and fill real values.
# Production values are injected by deploy/scripts/after_deploy.sh from SSM
# (/nomacom/client/DATABASE_URL + /nomacom/shared/maya/*).

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

MAYA_API_ENDPOINT=https://api.maya.net/connectivity/v1
MAYA_API_CLIENT_ID=
MAYA_API_CLIENT_SECRET=
