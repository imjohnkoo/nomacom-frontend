# apps/mobile local dev environment
# Copy to .env.local (gitignored) and adjust if client dev server runs elsewhere.
#
# EXPO_PUBLIC_* prefix is inlined into the JS bundle at build time.
# For iOS Simulator: http://localhost:3000 works as-is.
# For real device on same LAN: replace with your machine's LAN IP (e.g. http://192.168.x.x:3000).
# EAS production builds: set via `eas secret:create` per profile, not via .env.local.

EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
