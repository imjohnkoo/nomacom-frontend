{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PassCodeDeployRoleToEC2",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::059265294529:role/codeDeployRole",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ec2.amazonaws.com"
        }
      }
    },
    {
      "Sid": "PassCodeDeployServiceRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::059265294529:role/code-deploy",
        "arn:aws:iam::059265294529:role/code-deploy-v2"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "codedeploy.amazonaws.com"
        }
      }
    }
  ]
}
